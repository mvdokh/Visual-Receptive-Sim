# Take in an RGB triple, return a new triple that represents the
# LMS acivities.  0 <= r,g,b <= 255.  0 <= l,m,s <= 255
def RGB_to_LMS(rgb):
    global gRGB, lms_hash
    if lms_hash.has_key(rgb):
        return lms_hash[rgb]
    else:
        r,g,b = rgb
        gamma_r = gRGB[r,:,1]
        gamma_g = gRGB[g,:,2]
        gamma_b = gRGB[b,:,3]
        luminosity = gamma_r + gamma_g + gamma_b
        l = int(round(sum(luminosity * LMS[:,1]) * 255))
        m = int(round(sum(luminosity * LMS[:,2]) * 255))
        s = int(round(sum(luminosity * LMS[:,3]) * 255))
        if l > 255 | m > 255 | s > 255:
            print 'Warning: activity > 255. Cropping to 255 (l,m,s) = ', (l,m,s)
            if l > 255: l = 255
            if m > 255: m = 255
            if s > 255: s = 255
        if l < 0 | m < 0 | s < 0:
            print 'Warning: activity < 0. Cropping to 0 (l,m,s) = ', (l,m,s)
            if l < 0: l = 0
            if m < 0: m = 0
            if s < 0: s = 0
        # print 'RGB_to_LMS: ', rgb, '->', (l,m,s)
        lms_hash[rgb] = (l,m,s) 
        return (l,m,s)


# Do some file filering given the global RGB and LMS arrays.
# Then save to a file.  File types may be important later, but
# just use pgm for now.
def convert_file_to_LMS(infile, filename_prefix):
    if glob.glob(infile):
        print 'Converting', infile + '....',
        sys.stdout.flush()
        # Read in file, convert to RGB in case not already in that form,
        # convert to a list the pixel data, create new list of transformed
        # pixels, then paste back into original image before saving each
        # of the three channels into different files.
        i = read_image(infile)
        rgb_i = i.convert('RGB')
        rgb_pixels = list(rgb_i.getdata())
        lms_pixels = []
        for x in rgb_pixels:
            if FAST_COMPUTE: lms_pixels.append(fast_compute_lms(x))
            else: lms_pixels.append(RGB_to_LMS(x))
        rgb_i.putdata(lms_pixels)
        lms_i = rgb_i.split()
        lms_i[0].save(filename_prefix + L_EXTENSION + '.pgm')
        lms_i[1].save(filename_prefix + M_EXTENSION + '.pgm')
        lms_i[2].save(filename_prefix + S_EXTENSION + '.pgm')
        print 'done.'
    else:
        print infile, 'does not exist.'


# Generate a MATLAB file that will save the LMS, RGB and gRGB matrices
# and then generate three plots that show the different matrices for the
# purposes of debugging.
def save_matlab_matrix():
    global LMS, RGB, gRGB
    f = open('rgbtolms.m','w')
    f.write('% Generated by rgbtolms.py to show calculated functions\n')
    f.write('RGB = ' + array2string(RGB) + ';\n')
    f.write('LMS = ' + array2string(LMS) + ';\n')
    f.write('gRGB = zeros(256,' + str(LMS.shape[0]) + ',4);\n')
    for i in range(256):
        f.write('gRGB(' + str(i+1) + ',:,:) = ' + array2string(gRGB[i,:,:])
                + ';\n')
    f.write('''
         figure;
         hold on;
         plot(RGB(:,1),RGB(:,2),'red');
         plot(RGB(:,1),RGB(:,3),'green');
         plot(RGB(:,1),RGB(:,4),'blue');
         figure;
         hold on;
         plot(LMS(:,1),LMS(:,2),'black');
         plot(LMS(:,1),LMS(:,3),'black');
         plot(LMS(:,1),LMS(:,4),'black');
         figure;
         hold on;
         for i = 1:256
             plot(gRGB(i,:,1),gRGB(i,:,2));
             plot(gRGB(i,:,1),gRGB(i,:,3));
             plot(gRGB(i,:,1),gRGB(i,:,4));
         end''')

# Generate a C file that will save the LMS, RGB and GAMMA_FCN matrices
def save_c_matrix():

    def format_c_vector(v):
        """Format a vector into a bracketed list"""
        s = '{'
        for i in range(len(v)):
            s += '%f,' % (v[i])
	    if i % 5 == 4: s += '\n'
        s = s[:-1] + '}'
        return s
    def format_c_matrix(m):
        """Format a matrix into a bracketed list"""
        (r,c) = m.shape
        s = '{'
        for i in range(r):
            s += format_c_vector(m[i,:]) + ',\n'
        s = s[:-2] + '}'
        return s
            
    global LMS, RGB, GAMMA_FCN
    f = open('rgbtolms.h','w')
    f.write('// Auto-generated by rgbtolms.py to import into LISSOM 5.0\n\n')
    f.write('#define WAVELENGTH_POINTS %d\n\n' % (LMS.shape[0]))

    f.write('//Python:  def gamma(x): return pow(x,GAMMA)  # GAMMA = 2.2\n')
    f.write('float gamma_fcn[%d] = \n%s;\n\n'
            % (GAMMA_FCN.shape[0],format_c_vector(GAMMA_FCN)))

    tLMS = transpose(LMS[:,1:4])
    f.write('// LMS Cone sensitivity functions\n')
    f.write('// Stockman and Sharpe (2000) 10-deg cone fundamentals\n'
            + '// Based on the Stiles and Burch (1959) 10-deg CMFs\n')
    f.write('float lms_fcn[%d][%d] = \n%s;\n\n'
            % (tLMS.shape[0],tLMS.shape[1],format_c_matrix(tLMS)))

    tRGB = transpose(RGB[:,1:4])
    f.write('// RGB Spectral Power Distribution from Sony GDM 500.\n')
    f.write('// Provided by Tony Wilson. 2005-04-27\n')
    f.write('float rgb_fcn[%d][%d] = \n%s;\n\n'
            % (tRGB.shape[0],tRGB.shape[1],format_c_matrix(tRGB)))



def run_tests():
    """
    A few tests to make sure the program is creating correct values.
    """
    # r,g,b = 128,0,0
    # print '('+str(r)+','+str(g)+','+str(b)+') = ', RGB_to_LMS((r,g,b))
    assert RGB_to_LMS((0,0,0)) == (0,0,0), "Output not matched"
    assert RGB_to_LMS((85,85,85)) == (23,23,23), "Output not matched"
    assert RGB_to_LMS((128,128,128)) == (56,56,56), "Output not matched"
    assert RGB_to_LMS((170,170,170)) == (105,105,105), "Output not matched"
    assert RGB_to_LMS((255,255,255)) == (255,255,255), "Output not matched"
    assert RGB_to_LMS((255,0,0)) == (73,29,4), "Output not matched"
    assert RGB_to_LMS((0,255,0)) == (140,159,14), "Output not matched"
    assert RGB_to_LMS((0,0,255)) == (42,67,237), "Output not matched"


def setup_fast_compute_lms():
    """
    Initial setup for fast_compute_lms(), to avoid redundant testing
    """
    global lms_hash
    lms_hash[(255,0,0)] = RGB_to_LMS((255,0,0))
    lms_hash[(0,255,0)] = RGB_to_LMS((0,255,0))
    lms_hash[(0,0,255)] = RGB_to_LMS((0,0,255))

def fast_compute_lms(rgb):
    """
    
    Do a faster computation than RGB_to_LMS() using only the
    activation triples for LMS with Activation at max R, Activation at
    max G, and Activation at max B.  Does this by assuming a smooth
    Gamma function up to the maximum emission.  The L,M, and S
    activation triples at maximum emissions can be considered a new
    set of monitor guns that perfectly match the retinal sensitivity.
    The vector size of these equations are much smaller than the
    original.

    L,M,S = i^2.2
    L,M,S = r^2.2 + g^2.2 + b^2.2
    e^(2.2 * ln L) = r ....
    """
    global lms_hash
    if lms_hash.has_key(rgb):
        return lms_hash[rgb]
    else:
        (r,g,b) = rgb
        r = r / 255.0
        g = g / 255.0
        b = b / 255.0
        (lr,lg,lb) = lms_hash[(255,0,0)]
        (mr,mg,mb) = lms_hash[(0,255,0)]
        (sr,sg,sb) = lms_hash[(0,0,255)]
        if r > 0: r = log(r)
        else: lr,lg,lb = 0,0,0
        if g > 0: g = log(g)
        else: mr,mg,mb = 0,0,0
        if b > 0: b = log(b)
        else: sr,sg,sb = 0,0,0
        eGr = exp(GAMMA * r)
        eGg = exp(GAMMA * g)
        eGb = exp(GAMMA * b)
        l = int(round(eGr * lr + eGg * mr + eGb * sr))
        m = int(round(eGr * lg + eGg * mg + eGb * sg))
        s = int(round(eGr * lb + eGg * mb + eGb * sb))
#        l = int(round((exp(GAMMA * r) * lr + exp(GAMMA * g) * mr +
#                       exp(GAMMA * b) * sr)))
#        m = int(round((exp(GAMMA * r) * lg + exp(GAMMA * g) * mg +
#             exp(GAMMA * b) * sg)))
#        s = int(round((exp(GAMMA * r) * lb + exp(GAMMA * g) * mb +
#             exp(GAMMA * b) * sb)))
        lms = (l,m,s)
        # (r,g,b) = RGB_to_LMS(rgb)
        lms_hash[rgb] = lms
        # if (abs(r-l) > 1 or abs(g-m) > 1 or abs(b-s) > 1):
        #     print rgb, '-->', lms
    return (lms)

        
def main():
    t = time.time()
    options, args = process_command_line()
    load_filters()

    if FAST_COMPUTE: setup_fast_compute_lms()
    if DEBUG: run_tests()

    if os.name == 'nt':   # CMD will not expand wildcards like Linux shells. 
        files = []
        for f in args:
            files += glob(f)
    else:
        files = copy.copy(args)


    if files:
        counter = 0
        if options.prefix == None:
            options.prefix = ''
        for f in files:
            counter += 1
            filename_prefix = "%s%02d" % (options.prefix, counter)
            convert_file_to_LMS(f,filename_prefix)

    if options.matlab or options.cheader:
        print('Generating matrix files.')
    if options.matlab:
        save_matlab_matrix()
    if options.cheader:
        save_c_matrix()

    print 'Time:', time.time() - t, 'seconds.'
main()
