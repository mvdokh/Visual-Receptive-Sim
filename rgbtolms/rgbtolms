# Script to convert an RGB image to an LMS activity.
# An RGB pixel has to go through two filters to get an LMS pixel:
#  1. RGB pixel is converted to emission spectrum using a specified monitor
#  2. Emission spectrum is sampled using LMS curves
# REQUIRED PACKAGES
#  Numeric
#  PIL

import string, re, sys, glob, time, optparse, copy, os
import ImageFile, Image  # PIL
from Numeric import *

L_EXTENSION = '_lms_0' #Long
M_EXTENSION = '_lms_1' #Medium
S_EXTENSION = '_lms_2' #Short
DEBUG = False # True
GAMMA = 2.2
# Originally written using complete linear algebra matrix
# multiplications for each luminosity value.  Rewritten to use a new
# function that uses the assumption that the gamma function is smooth,
# and that once the activity triple for LMS is calculated for the
# maximum electron gun emission in isolation, a single linear
# combination of the three maximum R,G,B triples will suffice.
# RGB_to_LMS() and fast_compute_lms() will not always have exactly the
# same value due to rounding effects, but tests show that the variance
# is is not greater than +/- 1.
FAST_COMPUTE = True

# Conversion filter matrix
LMS = []       # Approximately 400x4
RGB = []       # Approximately 400x4
gRGB = []      # 256 * RGB.  Lookup table for gamma function
GAMMA_FCN = [] # Made global so the gammas can be saved. 
lms_hash = {}  # Store computed LMS activation for possible reuse.


def process_command_line():
    """Pull the parameters from the commandline"""
    parser = optparse.OptionParser()
    parser.add_option('-m', '--matlab', action='store_true', default=False, dest='matlab',
                      help='Generate matlab readable matrix file')
    parser.add_option('-c', '--cheader', action='store_true', default=False, dest='cheader',
                      help='Generate a c header file with the conversion matrices.')
    parser.add_option('-p', '--prefix', dest="prefix", 
                      help='Use PREFIX for output file names.', metavar="PREFIX")
    options, args = parser.parse_args()
    #if DEBUG:
    #    print 'Options', options, 'Args', args
    return (options, args)


# Expected file format is text file with each line having a four-tuple
# with a possible comma and spaces to delimit.  Read it all into an array.
# First number is wavelength in nm, other numbers are floats.
def read_triple(filename):
    f = open(filename,'r')
    pat = re.findall('([-+\deE\.]+)[,\s]+'
                     '([-+\deE\.]+)[,\s]+'
                     '([-+\deE\.]+)[,\s]+'
                     '([-+\weE\.]+)',f.read())
    f.close()
    wavelength = []
    for x in pat:
        wavelength.append([float(x[0]), float(x[1]), float(x[2]), float(x[3])])
    return array(wavelength)


# Some of the input data are not single-steped so I need to double the
# number of elements.  This assumes that every other whole number is
# skipped, so 2,4,6,8 becomes 2,3,4,5,6,7,8.
def stretch_array(inarray):
    temp_array = list(inarray)
    new_array = []
    for x in temp_array:
        w,x1,x2,x3 = x
        new_array.append(x)
        new_array.append([(w+1),x1,x2,x3])
    return array(new_array)


# In case I want to make the gamma function more complicated later.
def gamma(x): return pow(x,GAMMA)

# Takes the maximum luminosiy found in RGB and scales for each value
# of x in the gamma function.  Creates a 256xWAVELENGTHSx4 matrix which
# can be accessed as a lookup table.
def generate_gRGB():
    global RGB, gRGB, GAMMA_FCN
    gRGB = array([list(RGB)] * 256)          # Duplicates 1x400 to 256x400
    if DEBUG: print 'gRGB shape', gRGB.shape 
    for i in range(256):                     # Create the Gamma multipliers
        GAMMA_FCN.append(gamma(i))
    GAMMA_FCN = array(GAMMA_FCN)
    GAMMA_FCN = GAMMA_FCN / max(GAMMA_FCN)   # Normalize
    for i in range(256):                     # Reduce luminosity of x by Gamma
        gRGB[i,:,1:4] = gRGB[i,:,1:4] * GAMMA_FCN[i]
        

# Load the functions from the file, then trim to range that overlaps
# and normalize.
def load_filters():
    # Hack to get it to load the directories even if called remotely.
    # Must be changed if the length of the filename changes.
    p = sys.argv[0]
    p = p[0:len(p)-8]
    
    global LMS
    global RGB
    LMS = read_triple(p + 'LMS.txt')
    RGB = read_triple(p + 'RGB.txt')

    if DEBUG:
        print 'LMS Wavelengths: ', LMS[0,0], '->', LMS[shape(LMS)[0]-1,0]
        print 'RGB Wavelengths: ', RGB[0,0], '->', RGB[shape(RGB)[0]-1,0]

    # Where only one funcion is defined the other will zero it out,
    # so trim for only the overlapping regions
    active_min = max(min(LMS[:,0]),min(RGB[:,0]))
    active_max = min(max(LMS[:,0]),max(RGB[:,0]))

    # The following is because the specrometer does every 2 nm instead
    # of every nm.  May have to change if the dataset changes.
    RGB = stretch_array(RGB)

    l, u = 0, shape(RGB)[0]-1       # Don't know of a better way to find min.
    while RGB[l,0] < active_min: l = l + 1
    while RGB[u,0] > active_max: u = u - 1
    RGB = RGB[l:u+1,:]
    l, u = 0,shape(LMS)[0]-1        # Repeated code.  Write function?
    while LMS[l,0] < active_min: l = l + 1
    while LMS[u,0] > active_max: u = u - 1
    LMS = LMS[l:u+1,:]

    if DEBUG: print 'Active Region  : ', active_min,'->', active_max

    # Safety check in case the stepsize is off, and the number of elements
    # in LMS does not equal the number of elements in RGB.
    if LMS[:,0] != RGB[:,0]:
        print 'Fatal error: RGB(x,:) not equal to LMS(x,:)'
        sys.exit()

    # Normalize RGB so that the sum of the three areas equals 1.
    RGB[:,1:4] = RGB[:,1:4] / sum(sum(RGB[:,1:4]))
    # Normalize each sensitivity curve of LMS to a peak sensitivity of 1.
    LMS[:,1:2] = LMS[:,1:2] / max(max(LMS[:,1:2]))
    LMS[:,2:3] = LMS[:,2:3] / max(max(LMS[:,2:3]))
    LMS[:,3:4] = LMS[:,3:4] / max(max(LMS[:,3:4]))

    # There are different ways to normalize the LMS acivity cones.  One would
    # be to do as with the RGB: normalize the area of all three curves to sum
    # to 1.  Another would be to normalize the maximally activated to 1, then
    # the others cones relative to that.  I think the best way is to normalize
    # the area of each cone type to the maximal activity it may ever get.
    # This would make RGB(255,255,255) --> LMS(255,255,255)
    lum = sum(transpose(RGB[:,1:4]))     # Emission vector of CRT white light.
    l_activity = sum(LMS[:,1] * lum)
    m_activity = sum(LMS[:,2] * lum)
    s_activity = sum(LMS[:,3] * lum)
    LMS[:,1] = LMS[:,1] / l_activity
    LMS[:,2] = LMS[:,2] / m_activity
    LMS[:,3] = LMS[:,3] / s_activity
    generate_gRGB()

    if DEBUG:
        print 'Sum RGB(:,1:4)', sum(sum(RGB[:,1:4]))
        print 'Max LMS(:,1)', max(LMS[:,1])
        print 'Max LMS(:,2)', max(LMS[:,2])
        print 'Max LMS(:,3)', max(LMS[:,3])
        activity = sum(sum(LMS[:,1:4] * RGB[:,1:4]))
        print 'Summed LMS Activity to RGB White light', activity
        print 'RGB_to_LMS((255,255,255)): ', RGB_to_LMS((255,255,255))


